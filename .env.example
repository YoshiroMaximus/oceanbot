# Copy this file to .env and fill in your values.

# Your bot token from https://discord.com/developers/applications
# (your app → Bot → Reset Token)
DISCORD_TOKEN=paste-your-token-here

# Optional but recommended: your server's ID (right-click the server icon →
# Copy Server ID, with Developer Mode on). Makes /setup and /post appear
# instantly instead of taking up to an hour.
GUILD_ID=
