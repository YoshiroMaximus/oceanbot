# Copy this file to .env. It is only used by `npm run register`
# (the deployed Worker gets its settings from wrangler.jsonc and
# `npx wrangler secret put DISCORD_TOKEN` instead).

# From https://discord.com/developers/applications -> your app -> Bot -> Reset Token
DISCORD_TOKEN=paste-your-token-here

# From your app's General Information page
DISCORD_APPLICATION_ID=paste-your-application-id-here

# Optional but recommended: your server's ID (right-click the server icon ->
# Copy Server ID, with Developer Mode on). Makes commands appear instantly
# instead of taking up to an hour.
GUILD_ID=
